# Supabase PostgreSQL connection
# Copiá este archivo a .env y reemplazá con tus credenciales reales
user=postgres.TU_PROJECT_ID_AQUI
password=TU_PASSWORD_AQUI
host=aws-0-sa-east-1.pooler.supabase.com
port=5432
dbname=postgres

# Contraseña del admin inicial (usada solo por db/seed.py)
# Usá una contraseña fuerte antes de ejecutar seed.py
ADMIN_PASSWORD=TU_PASSWORD_ADMIN_AQUI
